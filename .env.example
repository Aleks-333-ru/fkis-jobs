# Скопируйте этот файл в .env и впишите свои ключи API.
# Запуск с ключами:  node --env-file=.env server.js
#
# hh.ru — данные приложения из https://dev.hh.ru (после одобрения заявки).
# Достаточно пары Client ID/Secret — токен сервер получит сам.
HH_CLIENT_ID=
HH_CLIENT_SECRET=
# ...или сразу готовый токен приложения (тогда ID/Secret не нужны):
HH_ACCESS_TOKEN=
#
# SuperJob — «Secret key» приложения с https://api.superjob.ru/register
SUPERJOB_KEY=
